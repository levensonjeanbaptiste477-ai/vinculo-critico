<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>Vínculo Crítico — Protótipo</title>
<style>
  :root{
    --bg-deep:#0d0e15;
    --bg-panel:#12141f;
    --neon:#00ffcc;
    --neon-dim:rgba(0,255,204,0.35);
    --purple:#7b2ff7;
    --purple-dim:rgba(123,47,247,0.35);
    --red:#ff2d55;
    --red-dim:rgba(255,45,85,0.35);
    --gold:#ffcc00;
    --text-main:#e7f7f4;
    --text-dim:#7f8a9c;
    --mono: 'Courier New', ui-monospace, monospace;
    --display: 'Segoe UI', system-ui, -apple-system, sans-serif;
  }

  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}

  html,body{
    margin:0; padding:0; height:100%;
    background:
      radial-gradient(circle at 20% 10%, rgba(123,47,247,0.12), transparent 40%),
      radial-gradient(circle at 80% 90%, rgba(0,255,204,0.08), transparent 40%),
      var(--bg-deep);
    font-family:var(--display);
    color:var(--text-main);
    display:flex;
    align-items:center;
    justify-content:center;
    min-height:100vh;
    overflow-x:hidden;
  }

  /* ============ BRANDING ATRÁS DO TELEFONE ============ */
  .brand-tag{
    position:fixed;
    top:18px; left:50%; transform:translateX(-50%);
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:3px;
    color:var(--text-dim);
    text-transform:uppercase;
    z-index:0;
  }

  /* ============ FRAME DO CELULAR ============ */
  .phone-shell{
    position:relative;
    width:390px;
    max-width:94vw;
    height:844px;
    max-height:92vh;
    background:linear-gradient(160deg,#1b1d29,#0a0b11 70%);
    border-radius:52px;
    padding:14px;
    box-shadow:
      0 0 0 2px rgba(255,255,255,0.04),
      0 0 40px rgba(0,255,204,0.08),
      0 30px 80px rgba(0,0,0,0.7),
      inset 0 0 2px rgba(255,255,255,0.05);
    z-index:1;
  }

  .phone-shell::before{ /* notch */
    content:'';
    position:absolute;
    top:14px; left:50%; transform:translateX(-50%);
    width:120px; height:26px;
    background:#000;
    border-radius:0 0 18px 18px;
    z-index:20;
  }

  .screen{
    position:relative;
    width:100%; height:100%;
    background:var(--bg-panel);
    border-radius:38px;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    border:1px solid rgba(0,255,204,0.08);
  }

  /* leve scanline/vinheta para clima cyberpunk */
  .screen::after{
    content:'';
    position:absolute; inset:0;
    pointer-events:none;
    background:
      linear-gradient(rgba(255,255,255,0.015) 50%, transparent 50%),
      radial-gradient(ellipse at center, transparent 60%, rgba(0,0,0,0.55) 100%);
    background-size: 100% 3px, 100% 100%;
    mix-blend-mode:overlay;
    z-index:30;
  }

  /* ============ STATUS BAR ============ */
  .statusbar{
    padding:34px 18px 10px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    font-family:var(--mono);
    font-size:13px;
    font-weight:bold;
    position:relative;
    z-index:5;
  }

  .stat{
    display:flex;
    align-items:center;
    gap:5px;
    padding:5px 9px;
    border-radius:10px;
    background:rgba(255,255,255,0.03);
    border:1px solid rgba(255,255,255,0.06);
    transition:all .2s ease;
  }

  .stat.gold{ color:var(--gold); }
  .stat.shield{ color:var(--neon); }
  .stat.timer{ color:#ff6ec7; }

  .stat.pulse-change{
    animation:statPulse .4s ease;
  }
  @keyframes statPulse{
    0%{ transform:scale(1); }
    40%{ transform:scale(1.25); }
    100%{ transform:scale(1); }
  }

  .shield-crit{
    color:var(--red) !important;
    animation:shieldCrit 0.8s infinite;
  }
  @keyframes shieldCrit{
    0%,100%{ opacity:1; }
    50%{ opacity:0.4; }
  }

  /* ============ ALERTA MUNDIAL ============ */
  .alert-box{
    margin:4px 14px 0;
    padding:10px 12px;
    border-radius:14px;
    background:linear-gradient(90deg, rgba(255,45,85,0.18), rgba(255,45,85,0.05));
    border:1px solid var(--red);
    font-size:11.5px;
    line-height:1.4;
    font-weight:600;
    color:#ffd7de;
    opacity:0;
    max-height:0;
    overflow:hidden;
    transition:opacity .35s ease, max-height .35s ease, margin .35s ease, padding .35s ease;
    position:relative;
    z-index:5;
  }
  .alert-box.show{
    opacity:1;
    max-height:120px;
    padding:10px 12px;
    animation:alertBlink 1s infinite;
  }
  @keyframes alertBlink{
    0%,100%{ box-shadow:0 0 6px 0 rgba(255,45,85,0.2); border-color:var(--red); }
    50%{ box-shadow:0 0 16px 4px rgba(255,45,85,0.55); border-color:#ff8aa3; }
  }

  /* ============ PAINEL CENTRAL VISUAL ============ */
  .world-panel{
    margin:14px 14px 0;
    border-radius:18px;
    height:150px;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:6px;
    position:relative;
    overflow:hidden;
    border:1px solid rgba(0,255,204,0.15);
    background:
      radial-gradient(circle at 30% 20%, rgba(0,255,204,0.10), transparent 55%),
      linear-gradient(180deg, #10321f, #0d1f17);
    transition:background 1s ease, border-color .6s ease;
    z-index:5;
  }

  .world-panel.burning{
    background:
      radial-gradient(circle at 40% 30%, rgba(255,140,0,0.35), transparent 60%),
      linear-gradient(180deg, #3a1108, #1a0805);
    border-color:rgba(255,60,20,0.5);
  }

  .world-icon{
    font-size:42px;
    filter:drop-shadow(0 0 10px rgba(0,255,204,0.5));
    transition:filter .6s ease;
  }
  .world-panel.burning .world-icon{
    filter:drop-shadow(0 0 14px rgba(255,90,20,0.8));
    animation:flicker 0.6s infinite alternate;
  }
  @keyframes flicker{
    from{ transform:scale(1) rotate(-1deg); }
    to{ transform:scale(1.06) rotate(1deg); }
  }

  .world-label{
    font-family:var(--mono);
    font-size:13px;
    letter-spacing:1px;
    color:var(--neon);
  }
  .world-panel.burning .world-label{ color:#ff8a4c; }

  .world-sub{
    font-size:10.5px;
    color:var(--text-dim);
  }

  /* partículas flutuantes sutis */
  .spark{
    position:absolute;
    width:3px; height:3px;
    border-radius:50%;
    background:var(--neon);
    opacity:0.6;
    animation:floatUp 3.5s linear infinite;
  }
  .world-panel.burning .spark{ background:#ff9d4d; }
  @keyframes floatUp{
    0%{ transform:translateY(20px); opacity:0; }
    20%{ opacity:0.8; }
    100%{ transform:translateY(-140px); opacity:0; }
  }

  /* ============ LOG DO MUNDO ============ */
  .log-wrap{
    margin:12px 14px 0;
    flex:1;
    min-height:0;
    display:flex;
    flex-direction:column;
    border-radius:14px;
    background:#07080d;
    border:1px solid rgba(0,255,204,0.12);
    overflow:hidden;
    z-index:5;
  }
  .log-title{
    font-family:var(--mono);
    font-size:10px;
    letter-spacing:2px;
    color:var(--neon);
    padding:8px 12px 6px;
    border-bottom:1px solid rgba(0,255,204,0.1);
    display:flex;
    justify-content:space-between;
  }
  .log-title .dot{
    display:inline-block; width:7px; height:7px; border-radius:50%;
    background:var(--neon); margin-right:6px;
    box-shadow:0 0 6px var(--neon);
    animation:dotBlink 1.4s infinite;
  }
  @keyframes dotBlink{ 0%,100%{opacity:1;} 50%{opacity:0.2;} }

  .log-body{
    flex:1;
    overflow-y:auto;
    padding:8px 12px 12px;
    font-family:var(--mono);
    font-size:10.8px;
    line-height:1.55;
    color:#8ff7dc;
    scroll-behavior:smooth;
  }
  .log-body::-webkit-scrollbar{ width:4px; }
  .log-body::-webkit-scrollbar-thumb{ background:var(--neon-dim); border-radius:4px; }

  .log-line{
    opacity:0;
    animation:logIn .3s ease forwards;
    margin-bottom:3px;
    word-break:break-word;
  }
  @keyframes logIn{
    from{ opacity:0; transform:translateY(4px); }
    to{ opacity:1; transform:translateY(0); }
  }
  .log-line.warn{ color:#ff8aa3; }
  .log-line.action{ color:var(--gold); }
  .log-line.good{ color:var(--neon); }

  /* ============ BOTÕES ============ */
  .actions{
    display:flex;
    gap:10px;
    padding:14px;
    z-index:5;
  }

  .btn{
    flex:1;
    border:none;
    border-radius:16px;
    padding:13px 8px;
    font-family:var(--display);
    font-weight:700;
    font-size:12.5px;
    color:#04110e;
    cursor:pointer;
    position:relative;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:4px;
    transition:transform .15s ease, filter .15s ease;
    -webkit-user-select:none; user-select:none;
  }
  .btn:active{ transform:scale(0.95); }

  .btn-burn{
    background:linear-gradient(135deg, #ff5f6d, #ff2d55);
    color:#2a0006;
    box-shadow:0 6px 18px rgba(255,45,85,0.35);
  }
  .btn-shield{
    background:linear-gradient(135deg, #00ffcc, #00c8ff);
    color:#00251f;
    box-shadow:0 6px 18px rgba(0,255,204,0.3);
  }
  .btn:disabled{
    opacity:0.4;
    filter:grayscale(0.5);
    cursor:not-allowed;
    transform:none;
  }
  .btn-title{ font-size:12.5px; }
  .btn-sub{ font-size:9.5px; font-weight:500; opacity:0.85; }

  .btn-ripple{
    position:absolute;
    border-radius:50%;
    background:rgba(255,255,255,0.55);
    transform:scale(0);
    animation:ripple .5s ease-out;
    pointer-events:none;
  }
  @keyframes ripple{
    to{ transform:scale(3); opacity:0; }
  }

  /* toast flutuante de ganho/perda */
  .float-toast{
    position:absolute;
    left:50%;
    top:120px;
    transform:translateX(-50%);
    font-family:var(--mono);
    font-weight:bold;
    font-size:15px;
    pointer-events:none;
    animation:toastFloat 1.1s ease forwards;
    z-index:40;
    text-shadow:0 0 8px currentColor;
  }
  @keyframes toastFloat{
    0%{ opacity:0; transform:translate(-50%, 10px) scale(0.8); }
    20%{ opacity:1; transform:translate(-50%, -10px) scale(1); }
    100%{ opacity:0; transform:translate(-50%, -60px) scale(1); }
  }

  /* game over overlay */
  .overlay{
    position:absolute; inset:0;
    background:rgba(5,6,10,0.92);
    display:none;
    flex-direction:column;
    align-items:center;
    justify-content:center;
    gap:10px;
    text-align:center;
    padding:30px;
    z-index:50;
    border-radius:38px;
  }
  .overlay.show{ display:flex; }
  .overlay h2{
    font-size:22px;
    color:var(--neon);
    margin:0;
    text-shadow:0 0 12px var(--neon-dim);
  }
  .overlay p{ color:var(--text-dim); font-size:13px; margin:0; max-width:260px; }
  .overlay .btn-shield{ margin-top:14px; width:160px; flex:none; }

  @media (max-width:400px){
    .phone-shell{ border-radius:38px; padding:10px; }
    .screen{ border-radius:28px; }
  }
</style>
</head>
<body>

<div class="brand-tag">VÍNCULO CRÍTICO // PROTÓTIPO COMERCIAL</div>

<div class="phone-shell">
  <div class="screen">

    <div class="statusbar">
      <div class="stat gold" id="statGold">💰 <span id="goldVal">250</span></div>
      <div class="stat shield" id="statShield">🛡️ <span id="shieldVal">100</span>%</div>
      <div class="stat timer" id="statTimer">⏱️ <span id="timerVal">03:00</span></div>
    </div>

    <div class="alert-box" id="alertBox"></div>

    <div class="world-panel" id="worldPanel">
      <div class="world-icon" id="worldIcon">🏞️</div>
      <div class="world-label" id="worldLabel">FLORESTA VIVA</div>
      <div class="world-sub" id="worldSub">Ecossistema estável — nenhuma ameaça próxima</div>
    </div>

    <div class="log-wrap">
      <div class="log-title"><span><span class="dot"></span>HISTÓRICO DO MUNDO</span><span id="logCount">0 eventos</span></div>
      <div class="log-body" id="logBody"></div>
    </div>

    <div class="actions">
      <button class="btn btn-burn" id="btnBurn">
        <span class="btn-title">🔥 Queimar Floresta</span>
        <span class="btn-sub">+100 Ouro instantâneo</span>
      </button>
      <button class="btn btn-shield" id="btnShield">
        <span class="btn-title">🛡️ Escudo Anti-IA</span>
        <span class="btn-sub">Custa 30 Ouro</span>
      </button>
    </div>

    <div class="overlay" id="overlay">
      <h2>⏱️ PARTIDA ENCERRADA</h2>
      <p>O tempo acabou. Sua rede de decisões impactou <b id="impactCount">0</b> jogadores ao redor do mundo — e você foi impactado por eles também.</p>
      <button class="btn btn-shield" id="btnRestart">🔁 Jogar Novamente</button>
    </div>

  </div>
</div>

<script>
(function(){
  // ---------- estado ----------
  let gold = 250;
  let shield = 100;
  let timeLeft = 180; // 3:00 em segundos
  let burning = false;
  let impacts = 0;
  let running = true;

  const goldVal = document.getElementById('goldVal');
  const shieldVal = document.getElementById('shieldVal');
  const timerVal = document.getElementById('timerVal');
  const statShield = document.getElementById('statShield');
  const statGold = document.getElementById('statGold');
  const alertBox = document.getElementById('alertBox');
  const worldPanel = document.getElementById('worldPanel');
  const worldIcon = document.getElementById('worldIcon');
  const worldLabel = document.getElementById('worldLabel');
  const worldSub = document.getElementById('worldSub');
  const logBody = document.getElementById('logBody');
  const logCount = document.getElementById('logCount');
  const btnBurn = document.getElementById('btnBurn');
  const btnShield = document.getElementById('btnShield');
  const overlay = document.getElementById('overlay');
  const impactCountEl = document.getElementById('impactCount');
  const screenEl = document.querySelector('.screen');

  let eventTotal = 0;

  // ---------- helpers ----------
  function pad(n){ return n.toString().padStart(2,'0'); }

  function updateHUD(pulseGold, pulseShield){
    goldVal.textContent = gold;
    shieldVal.textContent = Math.max(0, Math.round(shield));
    if(shield <= 30){
      statShield.classList.add('shield-crit');
    } else {
      statShield.classList.remove('shield-crit');
    }
    if(pulseGold){
      statGold.classList.remove('pulse-change'); void statGold.offsetWidth;
      statGold.classList.add('pulse-change');
    }
    if(pulseShield){
      statShield.classList.remove('pulse-change'); void statShield.offsetWidth;
      statShield.classList.add('pulse-change');
    }
  }

  function addLog(text, type){
    eventTotal++;
    const line = document.createElement('div');
    line.className = 'log-line' + (type ? ' ' + type : '');
    line.textContent = '['+ new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}) +'] ' + text;
    logBody.appendChild(line);
    logBody.scrollTop = logBody.scrollHeight;
    logCount.textContent = eventTotal + ' evento' + (eventTotal===1?'':'s');
    // limita histórico pra não crescer infinito
    while(logBody.children.length > 60){
      logBody.removeChild(logBody.firstChild);
    }
  }

  function floatToast(text, color){
    const t = document.createElement('div');
    t.className = 'float-toast';
    t.style.color = color;
    t.textContent = text;
    screenEl.appendChild(t);
    setTimeout(()=> t.remove(), 1150);
  }

  function setWorld(state){
    if(state === 'burning'){
      burning = true;
      worldPanel.classList.add('burning');
      worldIcon.textContent = '🔥';
      worldLabel.textContent = 'FLORESTA EM CHAMAS';
      worldSub.textContent = 'Visibilidade reduzida — monstros mais rápidos na região';
    } else {
      burning = false;
      worldPanel.classList.remove('burning');
      worldIcon.textContent = '🏞️';
      worldLabel.textContent = 'FLORESTA VIVA';
      worldSub.textContent = 'Ecossistema estável — nenhuma ameaça próxima';
    }
  }

  // partículas decorativas no painel
  function spawnSparks(){
    for(let i=0;i<5;i++){
      const s = document.createElement('div');
      s.className = 'spark';
      s.style.left = (10 + Math.random()*80) + '%';
      s.style.bottom = '10px';
      s.style.animationDelay = (Math.random()*3) + 's';
      worldPanel.appendChild(s);
      setTimeout(()=> s.remove(), 4000);
    }
  }
  const sparkInterval = setInterval(()=>{ if(running) spawnSparks(); }, 1600);
  spawnSparks();

  // ---------- alertas mundiais (Efeito Borboleta) ----------
  const worldEvents = [
    { text: '⚠️ @StreamerX ativou uma Bomba de Fumaça no Japão. Sua visibilidade caiu e monstros ficaram mais rápidos!', type:'vision' },
    { text: '⚠️ @NinjaBR sabotou a rede elétrica. Seu Escudo Global caiu 15%!', type:'shield', amount:15 },
    { text: '⚠️ @PixelQueen liberou um enxame na América do Sul. Seu Escudo Global caiu 10%!', type:'shield', amount:10 },
    { text: '⚠️ @GhostPlay derrubou uma ponte na Europa. Recursos ficaram 20% mais raros por instantes!', type:'gold_penalty', amount:20 },
    { text: '⚠️ @LunaTV congelou um setor no Canadá. Seu Escudo Global caiu 12%!', type:'shield', amount:12 },
    { text: '⚠️ @DarkWolf abriu uma fenda dimensional. Alertas em cascata detectados no servidor!', type:'vision' },
  ];

  function triggerWorldEvent(){
    if(!running) return;
    const ev = worldEvents[Math.floor(Math.random()*worldEvents.length)];
    impacts++;

    alertBox.textContent = ev.text;
    alertBox.classList.add('show');

    addLog(ev.text, 'warn');

    if(ev.type === 'shield'){
      shield = Math.max(0, shield - ev.amount);
      updateHUD(false, true);
      floatToast('-' + ev.amount + '% 🛡️', '#ff2d55');
    } else if(ev.type === 'gold_penalty'){
      floatToast('Recursos instáveis', '#ff8a4c');
    } else {
      floatToast('Visibilidade -', '#ff8a4c');
    }

    if(shield <= 0 && running){
      addLog('🚨 Seu Escudo Global colapsou! Você está totalmente exposto a ataques externos.', 'warn');
    }
  }

  const worldEventInterval = setInterval(triggerWorldEvent, 15000);
  // dispara o primeiro alerta um pouco mais cedo, pra demo ficar viva rápido
  setTimeout(triggerWorldEvent, 5000);

  // ---------- botões de decisão ----------
  function rippleEffect(btn, e){
    const rect = btn.getBoundingClientRect();
    const r = document.createElement('span');
    r.className = 'btn-ripple';
    const size = Math.max(rect.width, rect.height);
    r.style.width = r.style.height = size + 'px';
    const x = (e.touches ? e.touches[0].clientX : e.clientX) - rect.left - size/2;
    const y = (e.touches ? e.touches[0].clientY : e.clientY) - rect.top - size/2;
    r.style.left = x + 'px';
    r.style.top = y + 'px';
    btn.appendChild(r);
    setTimeout(()=> r.remove(), 500);
  }

  btnBurn.addEventListener('click', (e)=>{
    if(!running) return;
    rippleEffect(btnBurn, e);
    gold += 100;
    updateHUD(true, false);
    setWorld('burning');
    floatToast('+100 💰', '#ffcc00');
    addLog('🔥 Você queimou a floresta para extrair recursos rápidos. Em algum lugar do mundo, outro jogador acabou de perder visibilidade por sua causa.', 'action');
  });

  btnShield.addEventListener('click', (e)=>{
    if(!running) return;
    if(gold < 30){
      floatToast('Ouro insuficiente', '#ff2d55');
      return;
    }
    rippleEffect(btnShield, e);
    gold -= 30;
    shield = 100;
    updateHUD(true, true);
    alertBox.classList.remove('show');
    floatToast('Escudo 100% 🛡️', '#00ffcc');
    addLog('🛡️ Você ativou o Escudo Anti-IA. Sua defesa foi restaurada e as interferências externas foram neutralizadas.', 'good');
  });

  // ---------- cronômetro ----------
  const timerInterval = setInterval(()=>{
    if(!running) return;
    timeLeft--;
    if(timeLeft <= 0){
      timeLeft = 0;
      endGame();
    }
    const m = Math.floor(timeLeft/60);
    const s = timeLeft % 60;
    timerVal.textContent = pad(m) + ':' + pad(s);
  }, 1000);

  function endGame(){
    running = false;
    impactCountEl.textContent = impacts;
    overlay.classList.add('show');
  }

  document.getElementById('btnRestart').addEventListener('click', ()=>{
    location.reload();
  });

  // ---------- log inicial ----------
  addLog('🌍 Conectado ao servidor global. Sincronizando decisões de jogadores em tempo real...', 'good');
  addLog('🎮 Partida iniciada — você tem 3 minutos para tomar decisões que ecoam pelo mundo.', 'good');

})();
</script>

</body>
</html>
